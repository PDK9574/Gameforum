<!DOCTYPE html>
<html lang="en">
<head>
 
  <title>Document</title>
  <link rel="stylesheet" href="/stylesheets/board8.css">
  <link rel="stylesheet" href="/stylesheets/mouse.css">
</head>
<body>
  
  <div class="container">
    <div class="navbar">
      <img src="/images/logo.png" class="logo">
      <div class="logo-text">
        <img src="/images/logotext.png">
      </div>
      <div class="search">
        <form method="POST" action="/msgs/search/<%= id %>">
          <input class="inputtext" type="text" name="titlevalue" placeholder="search title">
          <label for="search"><i class="fas fa-search"></i></label>
          <input type="submit" id="search">
        </form>
      </div>
      <nav>
        <ul>
          
          <li><a href="/homepage"><i class="fas fa-home"></i><p>Home</p></a></li>
          <li><a href="/login"><i class="fas fa-sign-in-alt"></i><p>Login</p></a></li>
          <li><a href="/register"><i class="fas fa-registered"></i><p>Register</p></a></li>
          <li><a href="/users/grouplist"><i class="fas fa-users-cog"></i><p>group</p></a></li>
         
        </ul>
      </nav>
    </div>
    <div class="topbar">
      <div class="datas">
       
        
       
      </div>
    </div>
    <div class="row">
      <div class="rowcontent">         
        <div class="titleimg">
          <a href="/msgs/msglist/<%= id %>"><img src="/boardimages/board8.jpg"></a>
        </div>
        <% for(i=0;i<rows.length;i=i+2){ if(i==6){ break}  %>
        <div class="articles">
          <div class="article">
            <div class="contents">
              <div class="content">
                <div class="contentimg">
                  <% if(row[i]!= undefined) { %>
                  <img id="" src="/personimage/<%= row[i].photoname %>" alt="用戶無圖片">
                  <% }else { %>
                  <img src="/defaultimages/unknown.png">
                  <% } %>
                </div>
                <div class="text">
                  <text class="title" ><%= rows[i].title %></text>
                  <text class="text-content"><%= rows[i].content %></text>
                </div>
              </div>
            </div>
          </div>
        <% if (rows[i+1]!=undefined){ %>
          <div class="article">
            <div class="contents">
              <div class="content">
                <div class="contentimg">
                  <% if(row[i+1]!= undefined) { %>
                  <img id="" src="/personimage/<%= row[i+1].photoname %>">
                  <% }else { %>
                  <img src="/defaultimages/unknown.png">
                  <% } %>
                </div>
                <div class="text">
                  <text class="title"><%= rows[i+1].title %></text>
                  <text class="text-content"><%= rows[i+1].content %></text>
                </div>
              </div>
            </div>
          </div>
        </div> 
       <% } %>
        <% } %>
       
        </div> 
      </div>
    </div>
  </div>
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  <script>
   $(".text-content").each(function(){
        var len=$(this).text().length;   //當前HTML物件text的長度
        if(len>50){
            var str="";
            str=$(this).text().substring(0,40)+"......";  //使用字串擷取，獲取前30個字元，多餘的字元使用“......”代替
            $(this).html(str);                   //將替換的值賦值給當前物件
        }
    });
    
  </script>
</body>
</html>