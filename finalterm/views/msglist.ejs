<!DOCTYPE html>
<html lang="en">

<head>
  <title>Document</title>
  <link rel='stylesheet' href="/stylesheets/msglist.css">
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.5.0/css/all.css"
    integrity="sha384-B4dIYHKNBt8Bc12p+WXckhzcICo0wtJAoU8YZTY5qE0Id1GSseTk6S+L3BlXeVIU" crossorigin="anonymous">
  <style>
    

  </style>

</head>

<body>
  <div class="container">
    <audio id="grupvoice" loop  >
      <source  src="/music/grup voice.mp3" type="audio/mpeg">
    </audio>
    <div class="talklf">
      <p>hello</p>
    </div>
    <div class="talkrt">
      <p>hello</p>
    </div>
    <div class="grup-bg">
      <img class="right"  id=grup src="/images/grup.png">
    </div>
    <div class="background">
    </div>
    <div class="navbar">
      <img src="/images/logo.png" class="logo">
      <div class="logo-text">
        <img src="/images/logotext.png">
      </div>
      
      <div class="search">
        <form method="POST" action="/msgs/search/<%= id %>">
          <input class="inputtext" type="text" name="titlevalue" placeholder="search title">
          <label for="search"><i class="fas fa-search"></i></label>
          <input type="submit" id="search">
        </form>
      </div>
        <nav>
          <ul>
            <li><a href="/homepage"><i class="fas fa-home"></i><p>Home</p></a></li>
            <li><a href="/login"><i class="fas fa-sign-in-alt"></i><p>Login</p></a></li>
            <li><a href="/register"><i class="fas fa-registered"></i><p>Register</p></a></li>
            <li><a href="/users/grouplist"><i class="fas fa-users-cog"></i><p>group</p></a></li>
          </ul>
        </nav>
    </div>
    <div class="topbar">
      <div class="datas">
        <div class="create">
          <a href="/msgs/create/<%= id %>">new message</a>
        </div>
        <div class="data">
          <a href="/users">userdata</a>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="main">
        <div class="rowlabel">
          <div id="label1" class="label">
            <text>1</text>
          </div>
          <div id="label2" class="label">
            <text>2</text>
          </div>
          <div id="label3" class="label">
            <text>3</text>
          </div>
          <div id="label4" class="label">
            <text>4</text>
          </div>
          <div id="label5" class="label">
            <text>5</text>
          </div>
          <div id="label6" class="label">
            <text>6</text>
          </div>
        </div>
        <div class="rowcontent">
              <div class="list-filter">
                <div class="trangle">

                </div>
                <div class="filter-title">
                  <p>title</p>
                </div>
                <div class="filter-author">
                  <p>author</p>
                </div>
                <div class="filter-time">
                  <p>time</p>
                </div>
              </div>
          <% for(var i=0 ;i<10;i++){ %>
            <% if(rows[i]!=undefined) {%>
              <div id="list<%= i+1 %>" class="list<%= i%2 %>">
                 
                <div id="listid<%= i+1 %>" class="listid">
                  <p>Popularity</p>
                  <% if(rate[i]!=undefined) { %>
                  <%= rate[i].click %>
                  <% }else{ %>
                      0
                  <% } %>
                </div>
                <div class="listtitle-listcontent">
                  <div class="listtitle">
                    <a id="listtitle<%= i+1 %>" href="/msgs/lookarticle/<%= id %>/<%= rows[i].id %>">
                      <%= rows[i].title %>
                    </a>
                  </div>
                  <text id="listcontent<%= i+1%>" class="listcontent">
                    <%= rows[i].content %>
                  </text>
                </div>
                <div id="listauthor<%= i+1 %>" class="listauthor">
                  <%= rows[i].authorname %>
                </div>
                <div id="listupdatedtime<%= i+1 %>" class="listupdatedtime">
                  <%= rows[i].lastupdatedtime %>
                </div>
              </div>

            <% } %>
          <% } %>
                  <% for(var i=0 ;i<rows.length;i++){ %>
                    <% if(rows[i]!=undefined) {%>
                      <% if(rate[i]!=undefined){ %>
                      <input class="hiddenclick" type="hidden" value="<%= rate[i].click %>">
                      <% } else{  %>
                        <input class="hiddenclick" type="hidden" value="0">
                      <% } %> 
                      <input class="hiddentitle" type="hidden" value="<%= rows[i].title %>">
                      <input class="hiddencontent" type="hidden" value="<%= rows[i].content %>">
                      <input class="hiddenauthor" type="hidden" value="<%= rows[i].authorname %>">
                      <input class="hiddenlastupdatedtime" type="hidden" value="<%= rows[i].lastupdatedtime %>">
                      <% } %>
                  <% } %>
        </div>
      </div>
      <div class="sidebar">
      
        <div class="sidebar-top">
          <div class="trangle-side">

          </div>
          <p>Recommend</p>
        </div>
       
          <div class="sidebar-block-content">
            <img src="/images/loop hero.png">
            <a href="https://www.pcgamer.com/loop-hero-boss-secret-first-rewards/">Loop Hero boss guide: How to defeat them all, and the rewards you get</p>
            </a>
          </div>
        
        
          <div class="sidebar-block-content">
            <img src="/images/monster.jpg">
            <a href="https://www.monsterhunter.com/world-iceborne/hk/topics/at-velkhana/">Free major update fifth bullet Post attention activity tasks "The King of Fighting Bing Yulong" is here!</p>
            </a>
            
          </div>
       
       
          <div class="sidebar-block-content">
            <img src="/images/black survival eternal return.jpg">
            <a href="https://playeternalreturn.com/tcn/">"Eternal Reincarnation" is a unique and exciting all-round multiplayer survival game</p>
            </a>
          </div>
       
      </div>
    </div>
  </div>
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  <script>
  
    let click = document.querySelectorAll(".hiddenclick");
    let title = document.querySelectorAll(".hiddentitle")
    let content = document.querySelectorAll(".hiddencontent")
    let author = document.querySelectorAll(".hiddenauthor")
    let lastupdatedtime = document.querySelectorAll(".hiddenlastupdatedtime")
  
    function limitContent() {
      $(".listcontent").each(function () {
        var len = $(this).text().trim().length;   //當前HTML物件text的長度
       
        if (len > 50) {
          var str = "";
          str = $(this).text().substring(0, 50) + "......";  //使用字串擷取，獲取前50個字元，多餘的字元使用“......”代替
          $(this).html(str);                   //將替換的值賦值給當前物件
        }
      });
    }
    limitContent()

    
    function changePage(page) {
      let pageid = 0;
      for (i = (page-1)*10; i <page*10 ; i++) {
        pageid += 1;
        if (title[i] != undefined && click[i] != undefined && content[i] != undefined && author[i] != undefined && lastupdatedtime[i] != undefined) {
         
          console.log(click[i])
          $(`#list${pageid}`).css({"border-bottom": "0.5px solid gray" })
          $(`.list1`).css({"background":"#75D5FF"});
          $(`#listid${pageid}`).html("<p>Popularity</p>"+click[i].value);
          $(`#listtitle${pageid}`).text(title[i].value)
          $(`#listcontent${pageid}`).text(content[i].value)
          $(`#listauthor${pageid}`).text(author[i].value)
          $(`#listupdatedtime${pageid}`).text(lastupdatedtime[i].value)

        } else {
          console.log(click[i])
          $(`#listid${pageid}`).text("");
          $(`#listtitle${pageid}`).text("")
          $(`#listcontent${pageid}`).text("")
          $(`#listauthor${pageid}`).text("")
          $(`#listupdatedtime${pageid}`).text("")
          $(`#list${pageid}`).css({ "border-bottom": "none" ,"background" : "none"})
       
        }
      }
     

    }
    //換頁
    $("#label1").on({
      "click": function () {

          changePage(1)
          
          limitContent()
      
      }
    })
    $("#label2").on({
      "click": function () {
        changePage(2)
        
        limitContent()
      }
    })
    $("#label3").on({
      "click": function () {
        changePage(3);
        limitContent()
      }
    })
    /*var grup = document.getElementById("grup");
    $("#grup").on("click",function () {
        grup.classList.toggle("active");
      }
    )
    grup.addEventListener("animationend",function(){
      $("#grup").css("transform","scaleX(-1)");
    })*/
    var grupvoice=document.getElementById("grupvoice");
    //移動毛蟲,移動背景
    $(".grup-bg").off("click",".right").on("click",".right",function (e) {
      
        $("#grup").css("transform","none");
        $("#grup").addClass("active")
        $(".background").removeClass("right")
        $(".background").addClass("left")
        $(".right").off("animationend").on("animationend",function(e) {
          $("#grup").css("right","1700px");
          $("#grup").css("transform","rotateY(180deg)");
          $("#grup").removeClass("active right").addClass("left");
          $(".talkrt").css("visibility","hidden");
         console.log("rt");
         e.stopPropagation();
          return false
        })
        e.stopPropagation();
        return false
      })
      $(".grup-bg ").off("click",".left").on("click",".left",function (e) {
        $("#grup").css("transform","none");
        $("#grup").addClass("active")
        $(".background").removeClass("left")
        $(".background").addClass("right")
        $(".left").off("animationend").on("animationend",function(e) {
          $("#grup").css("right","100px");
          $("#grup").css("transform","scaleX(1)");
          $("#grup").removeClass("active left").addClass("right");
          $(".talklf").css("visibility","hidden");
          console.log("lf");
          e.stopPropagation();
          return false
        })
        e.stopPropagation();
        return false
      }
    )
    //毛蟲文字
    function Random(min,max){
      return Math.floor(Math.random()*(max-min)+min);
    }
    var gruptext=["mimama","mamumuhmu","ma mawo"];
    
    $(".grup-bg").on("mouseover",".right",function(e){
      $(".talkrt").css("visibility","visible");
      $(".talkrt").html("<p>"+gruptext[Random(0,3)]+"</p>");
      grupvoice.play();
    })
    $(".grup-bg").on("mouseleave",".right",function(e){
      $(".talkrt").css("visibility","hidden");
      grupvoice.pause();
    })
    $(".grup-bg").on("mouseover",".left",function(e){
      $(".talklf").css("visibility","visible");
      $(".talklf").html("<p>"+gruptext[Random(0,3)]+"</p>");
      grupvoice.play();
    })
    $(".grup-bg").on("mouseleave",".left",function(e){
      $(".talklf").css("visibility","hidden");
      grupvoice.pause();
    })
    //use 

   
  </script>


</body>

</html>