<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/navbar.css">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/group.css">
</head>

<body>
    <div class="container">
        <div class="navbar">
            <img src="/images/logo.png" class="logo">
            <div class="logo-text">
              <img src="/images/logotext.png">
            </div>
            <nav>
                <ul>
                    <li><a href="/homepage"><i class="fas fa-home"></i><p>Home</p></a></li>
                    <li><a href="/login"><i class="fas fa-sign-in-alt"></i><p>Login</p></a></li>
                    <li><a href="/register"><i class="fas fa-registered"></i><p>Register</p></a></li>
                    <li><a href="/users/grouplist"><i class="fas fa-users-cog"></i><p>group</p></a></li>
                </ul>
            </nav>
        </div>
        <div class="row">
            <div class="sidebar">
                <div class="sidebar-top">
                    <div class="search">
                       
                    </div>
                    <div class="users">
                        <% for(i=0;i<rows.length;i++){ %>
                        <div class="user">
                            <img src="/personimage/<%= rows[i].photoname %>" alt="用戶沒圖片">
                            <p><%= rows[i].username %></p>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
            <div class="chatmessage">
                <div class="groupname">
                    <p>sunshine</p>
                </div>
                <div class="messages">
                    <% for(i=0;i<row.length;i++){ %>
                    <% if(row[i]!=undefined){ %>
                    <div class="message">
                        <p class="name"><%= row[i].username %> <span><%= row[i].time %></span></p>
                        <p class="text"><%= row[i].text %></p>
                    </div>
                    <% } %>
                    <% } %>
                  
                </div>
                <div class="sendmessage">
                    <form action="/users/grouptext/<%= groupname %>" method="POST">
                        <input id="grouptext" name="grouptext" type="text" placeholder="send message"   required>
                        <input  class="sendtext" id="sendtext" type="submit" value="submit text" onclick="textFocus()">
                    </form>
                </div>
            </div>

        </div>
    </div>
    </div>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script>
        function textFocus(){
           document.getElementById("grouptext").focus();
        }
    </script>
</body>

</html>