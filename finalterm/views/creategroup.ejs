<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/navbar.css">
    <link rel="stylesheet" href="/stylesheets/creategroup.css">
    <script>
        //http://127.0.0.1:3000/users/creategroup
    </script>
</head>

<body>
    <div class="container">
        <div class="navbar">
            <img src="/images/logo.png" class="logo">
            <div class="logo-text">
                <img src="/images/logotext.png">
            </div>
            <nav>
              <ul>
                <li><i class="fas fa-times" id="close" onclick="shut()"></i></li>
                <li><a href="/homepage"><i class="fas fa-home"></i><p>Home</p></a></li>
                <li><a href="/login"><i class="fas fa-sign-in-alt"></i><p>Login</p></a></li>
                <li><a href="/register"><i class="fas fa-registered"></i><p>Register</p></a></li>
                <li><a href="/users/grouplist"><i class="fas fa-users-cog"></i><p>group</p></a></li>
                <li><i class="fas fa-bars" id="menu" onclick="show()"></i></li>
              </ul>
            </nav>
          </div>
        <div class="row">
            <div class="sidebar">
                <div class="sidebar-top">
                   
                    <div class="search">
                    <form action="/users/searchfriend" method="POST">
                        <input name="friendname" type="text" placeholder="search friend">
                        <label for="search"><i class="fas fa-search"></i></label>
                        <input  type="submit" id="search">
                    </form>
                    </div>
                    
                    <div class="users">
                        <a href="/users/addfriend">
                        <div class="user">
                            <i class="fas fa-user-plus"></i>
                            <p>add friend</p>
                        </div>
                        </a>
                        <a href="/users/friendreq">
                            <div class="user">
                                <i class="fas fa-user-check"></i>
                                <p>friend accept</p>
                            </div>
                        </a>
                        <a href="/users/friendlist">
                        <div class="user">
                            <i class="fas fa-user-friends"></i>
                            <p>friendlist</p>
                        </div>
                        </a>
                        <a href="/users/creategroup">
                        <div class="user">
                            <i class="fas fa-users"></i>
                           <p>create group</p>
                        </div>
                        </a>
                        <a href="/users/grouplist">
                        <div class="user">
                            <i class="fas fa-users-cog"></i>
                            <p>grouplist</p>
                        </div>
                        </a>
                    </div>
                </div>
                <div class="sidebar-bottom">
                    <input type="button">
                </div>
            </div>
            <div class="chatmessage">
                <div class="groupname">
                    <p>friendlist</p>
                </div>
                <div class="messages">
                    <% for(i=0;i<rows.length;i++){ %>
                        <% if (rows[i]!=undefined){ %>
                    <div class="message">
                      
                        <p class="name">groupname:<%= rows[i].name %></p>
                        
                        <p class="name">users:<%= member[i].length %></p>
                        <p class="name">grouphostid:<%= rows[i].hostid%></p>
                        <form action="/users/group/<%= rows[i].id %>" method="GET">
                            <input type="submit" value="enter">
                        </form>
                    </div>
                        <% } %>
                    <% } %>
                  
                </div>
              
            </div>

        </div>
    </div>
    </div>
    <a href="/users/deletefriend">delete</a>
        <form method="POST">
            <text>group name</text>
            <input id="gname" name="gname" type="text" required>
            <label>friend list</label><br>
            <% for(i=0;i<row.length;i++){ %>
            <% if (row[i]!=undefined){ %>
          
            <input name="members" id="friend<%= row[i].id %>"  type="checkbox" value="<%= row[i].id %>" >  <text  value="<%= row[i].id %>">"friend id":<%= row[i].id %>+friend name:<%= row[i].username%></text> 
            
                <br>
            <% } %>
            <% } %>
            <input type="submit" value="create">
        </form>
        <form action="/users/grouptext" method="POST">
            <texr>text</texr>
            <input name="grouptext" type="text">
            <input type="submit" value="submit text">
        </form>
        <form action="/users/getmembers" method="POST">
            <text>member</text>
            <input name="grouptext" type="text">
            <input type="submit" value="member ">
        </form>
        <a href="/users/grouplist">grouplist</a>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script> 
    <script>
        $()
    </script>
</body>
