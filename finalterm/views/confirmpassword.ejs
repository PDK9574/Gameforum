<html lang="en">
<head>
    <title>Document</title>
    <link rel='stylesheet' href="/stylesheets/navbar.css">
    <link rel="stylesheet" href="/stylesheets/confirmpassword.css">
</head>

<body>
    <div class="container">
        <div class="navbar">
            <img src="/images/logo.png" class="logo">
            <div class="logo-text">
              <img src="/images/logotext.png">
            </div>
            <nav>
              <ul>
                <li><i class="fas fa-times" id="close" onclick="shut()"></i></li>
                <li><a href="/homepage"><i class="fas fa-home"></i><p>Home</p></a></li>
                <li><a href="/login"><i class="fas fa-sign-in-alt"></i><p>Login</p></a></li>
                <li><a href="/register"><i class="fas fa-registered"></i><p>Register</p></a></li>
                <li><a href="/users/grouplist"><i class="fas fa-users-cog"></i><p>group</p></a></li>
                <li><i class="fas fa-bars" id="menu" onclick="show()"></i></li>
              </ul>
            </nav>
          </div>
        <div class="href"></div>
        <div class="row">
            <div class="rowcontent">
                <form method="POST">
                    <div class="login">
                        <section>verification code</section>
                    </div>
                    <div class="content">
                        <i class="fas fa-envelope"></i>
                        <input type="number" id="confirmpwd" name="confirmpwd" placeholder="confirmpassword" onkeypress="checkTitle()">
                    </div>
                    <div class="content">
                        <input type="submit">
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script>
         function checkTitle(){
            let confirmpwd =document.getElementById("confirmpwd")
            console.log(confirmpwd.value.length)
            if (confirmpwd.value.length>5){
               
                event.returnValue=false;
             }
        }
    </script>


</body>

</html>